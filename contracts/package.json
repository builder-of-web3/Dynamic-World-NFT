{
  "name": "dynamic-world-nft-contracts",
  "version": "1.0.0",
  "description": "Dynamic World NFT smart contracts for Optimism",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network optimism-sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network optimism",
    "deploy:soneium": "hardhat run scripts/deploy.js --network soneium",
    "verify": "hardhat verify"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  }
}
